# Copy to .env and adjust for your environment.

# SQLite (default) — file relative to the api/ working directory.
DATABASE_URL=sqlite:///./zealthy.db

# Auth — CHANGE THIS in production (must be >= 32 bytes).
JWT_SECRET=dev-secret-change-in-production-0123456789abcdef

# Comma-separated list of allowed frontend origins (CORS).
FRONTEND_ORIGINS=http://localhost:3000

# Cookie flags. Local dev: lax / not-secure. Cross-site prod (Vercel + separate
# API host): set COOKIE_SAMESITE=none and COOKIE_SECURE=true (requires HTTPS).
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
